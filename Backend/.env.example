PLIVO_CREDIT_USD_TO_INR_RATE=80
PROVIDER_REQUEST_TIMEOUT_MS=15000
PLIVO_BALANCE_REQUEST_TIMEOUT_MS=6000
PROVIDER_BALANCE_CACHE_TTL_SECONDS=60
PROVIDER_BALANCE_CACHE_TIMEOUT_MS=500
PUBLIC_BASE_URL=https://api.voice.zeacrm.com
VOICE_MEDIA_SIGNING_SECRET=
VOICE_MEDIA_TOKEN_TTL_SECONDS=120
VOICE_CALL_SESSION_TTL_SECONDS=3600
VOICE_MEDIA_MAX_MESSAGE_BYTES=65536
VOICE_MEDIA_MAX_PENDING_MESSAGES=250
VOICE_MEDIA_IDLE_TIMEOUT_MS=45000
VOICE_COMPANY_DEFAULT_CONCURRENCY=20
VOICE_CALL_OWNERSHIP_TTL_SECONDS=60
VOICE_CALL_HEARTBEAT_INTERVAL_MS=15000
VOICE_RUNTIME_INSTANCE_ID=
VOICE_SHUTDOWN_DRAIN_MS=5000
VOICE_AUDIO_FRAME_MS=20
VOICE_AUDIO_INPUT_MAX_BUFFER_MS=1000
VOICE_AUDIO_OUTPUT_MAX_BUFFER_MS=2000

NODE_ENV=development
HOST=0.0.0.0
PORT=1112
LOG_LEVEL=info
CORS_ORIGINS=https://voice.zeacrm.com,http://localhost:5020
PERFORMANCE_MEASUREMENT_ENABLED=true
PERFORMANCE_SLOW_REQUEST_MS=2000

DATABASE_URL=postgresql://user:password@localhost:5432/zea_voice
AUTO_MIGRATE=true
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=30000

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_COMMAND_TIMEOUT_MS=5000
REDIS_MAX_RETRY_DELAY_MS=3000
QUEUE_PREFIX=zea-voice
QUEUE_CONGESTED_WAITING=20
QUEUE_CRITICAL_WAITING=100
QUEUE_CONGESTED_WAIT_SECONDS=60
QUEUE_CRITICAL_WAIT_SECONDS=180
WORKER_HEARTBEAT_TTL_SECONDS=30
DASHBOARD_QUEUE_TIMEOUT_MS=1000

ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_BCRYPT_ROUNDS=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
REFRESH_COOKIE_NAME=zea_refresh_token
AUTH_COOKIE_SECURE=false
CREDENTIAL_ENCRYPTION_KEY=
PLIVO_API_BASE_URL=https://api.plivo.com/v1
PLIVO_CREDIT_USD_TO_INR_RATE=80
PROVIDER_REQUEST_TIMEOUT_MS=15000
PLIVO_BALANCE_REQUEST_TIMEOUT_MS=6000
PROVIDER_BALANCE_CACHE_TTL_SECONDS=60
PROVIDER_BALANCE_CACHE_TIMEOUT_MS=500
PUBLIC_BASE_URL=https://api.voice.zeacrm.com
PLIVO_ANSWER_URL=https://voice.zeacrm.com/webhook
CAMPAIGN_WORKERS_ENABLED=true
CAMPAIGN_WORKER_CONCURRENCY=20
CONCURRENCY_RETRY_DELAY_MS=5000

SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_FIRST_NAME=
SUPER_ADMIN_LAST_NAME=

B2_S3_ENDPOINT=
B2_REGION=
B2_BUCKET=
B2_BUCKET_ID=
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_SKIP_STARTUP_CHECK=true

NODE_ENV=development
HOST=0.0.0.0
PORT=1112
LOG_LEVEL=info
CORS_ORIGINS=https://voice.zeacrm.com,http://localhost:5020
PERFORMANCE_MEASUREMENT_ENABLED=true
PERFORMANCE_SLOW_REQUEST_MS=2000

DATABASE_URL=postgresql://user:password@localhost:5432/zea_voice
AUTO_MIGRATE=true
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=30000

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_COMMAND_TIMEOUT_MS=5000
REDIS_MAX_RETRY_DELAY_MS=3000
QUEUE_PREFIX=zea-voice
QUEUE_CONGESTED_WAITING=20
QUEUE_CRITICAL_WAITING=100
QUEUE_CONGESTED_WAIT_SECONDS=60
QUEUE_CRITICAL_WAIT_SECONDS=180
WORKER_HEARTBEAT_TTL_SECONDS=30
DASHBOARD_QUEUE_TIMEOUT_MS=1000

ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_BCRYPT_ROUNDS=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
REFRESH_COOKIE_NAME=zea_refresh_token
AUTH_COOKIE_SECURE=false
CREDENTIAL_ENCRYPTION_KEY=

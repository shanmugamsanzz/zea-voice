VOICE_WELCOME_CACHE_MAX_BYTES=2097152
VOICE_WELCOME_CACHE_TIMEOUT_MS=50
VOICE_POSTCALL_TIMEOUT_MS=5000
VOICE_POSTCALL_MAX_RESPONSE_BYTES=65536
VOICE_PRECALL_TIMEOUT_MS=5000
VOICE_PRECALL_MAX_RESPONSE_BYTES=65536
CAMPAIGN_WORKERS_ENABLED=true
CAMPAIGN_WORKER_CONCURRENCY=20
CONCURRENCY_RETRY_DELAY_MS=5000

SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_FIRST_NAME=
SUPER_ADMIN_LAST_NAME=

B2_S3_ENDPOINT=
B2_REGION=
B2_BUCKET=
B2_BUCKET_ID=
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_SKIP_STARTUP_CHECK=true
KNOWLEDGE_PDF_MAX_BYTES=26214400
KNOWLEDGE_PDF_MAX_PAGES=500
KNOWLEDGE_EXTRACTED_TEXT_MAX_CHARS=2000000
KNOWLEDGE_WORKERS_ENABLED=true
KNOWLEDGE_WORKER_CONCURRENCY=2
RAG_CHUNK_SIZE_TOKENS=300
RAG_CHUNK_OVERLAP_TOKENS=50
RAG_EMBEDDING_BATCH_SIZE=16
RAG_EMBEDDING_MAX_CHARS=1800
QDRANT_UPSERT_BATCH_SIZE=64
RAG_RUNTIME_PROFILE_CACHE_TTL_SECONDS=30
RAG_RUNTIME_RESULT_CACHE_TTL_SECONDS=30
RAG_RUNTIME_CACHE_TIMEOUT_MS=50
RAG_RUNTIME_TOP_K=3
RAG_RUNTIME_MIN_SCORE=0.72
LLM_REQUEST_TIMEOUT_MS=15000
LLM_CIRCUIT_FAILURE_THRESHOLD=5
LLM_CIRCUIT_RESET_TIMEOUT_MS=30000
LLM_MAX_OUTPUT_TOKENS=300
LLM_MAX_HISTORY_MESSAGES=12

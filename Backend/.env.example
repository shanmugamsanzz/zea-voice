# Phase 1 RAG infrastructure. The embedding model and dimensions are intentionally frozen.
RAG_ENABLED=false
RAG_STARTUP_CHECK_ENABLED=true
RAG_HEALTH_CACHE_TTL_MS=60000
EMBEDDING_BASE_URL=http://127.0.0.1:1113
EMBEDDING_API_KEY=
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIMENSIONS=384
EMBEDDING_REQUEST_TIMEOUT_MS=5000
EMBEDDING_BENCHMARK_ITERATIONS=10
EMBEDDING_BENCHMARK_TARGET_P95_MS=250

QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=zea_voice_company
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=Cosine
QDRANT_REQUEST_TIMEOUT_MS=3000
